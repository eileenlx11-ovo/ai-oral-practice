# Frontend
VITE_API_BASE=http://localhost:8001

# LLM (OpenAI-compatible: Deepseek, OpenAI, Zhipu, etc.)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ASR (SiliconFlow — domestic, OpenAI-compatible)
SILICONFLOW_API_KEY=your-siliconflow-api-key

# --- Pronunciation assessment (multi-provider, tried in priority order) ---
# Priority: Azure → Tencent SOE → mock. Leave all blank to use mock
# (fake scores, lets the UI work for demos). Set PRONUNCIATION_ALLOW_MOCK=0
# to disable mock and force a 503 when no real provider is configured.

# 1. Azure Speech (strongest: prosody + phoneme-level + miscue)
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=eastasia

# 2. Tencent Cloud SOE (domestic fallback, China-accessible)
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
TENCENT_SOE_REGION=ap-shanghai

# mock toggle (1 = allow mock fallback, 0 = disable)
PRONUNCIATION_ALLOW_MOCK=1
